APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:////var/www/jordansjobfinder/jordansjobfinder.db
BASE_URL=https://jordansjobfinder.com

# Email delivery for magic links
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CITY_PLAN_PRICE_ID=
STRIPE_UNLOCK_PRICE_ID=

# Cloudflare Turnstile bot protection (REQUIRED in production).
# Because APP_ENV=production, signup + login fail CLOSED: they are rejected
# until both keys below are set. Get them from the Cloudflare Turnstile
# dashboard (site key is public/embedded in the form; secret key is private).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
